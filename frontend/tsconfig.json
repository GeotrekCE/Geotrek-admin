{
  "compilerOptions": {
    "lib": ["ES2022", "ES2025.Intl", "DOM", "DOM.Iterable", "webworker"],
    "target": "ES2022",
    "module": "ESNext",
    "types": ["vite/client", "@serwist/vite/typings"],
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    },
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
}

